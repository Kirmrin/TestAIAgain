# API ключи для LLM
OPENAI_API_KEY=your_openai_api_key_here
GIGACHAT_API_KEY=your_gigachat_api_key_here
GIGACHAT_TOKEN=your_gigachat_token

# Настройки базы данных (если используется)
DATABASE_URL=sqlite:///./data/prompts.db

# Настройки логирования
LOG_LEVEL=INFO
LOG_FILE=logs/system.log

# Настройки API сервера
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# Настройки безопасности
SECRET_KEY=your_secret_key_here
ALLOWED_HOSTS=localhost,127.0.0.1

# Настройки хранилища
STORAGE_DIR=data
MAX_FILE_SIZE=10485760  # 10MB

# Настройки агентов
DEFAULT_MODEL=gpt-4
MAX_TOKENS=1000
TEMPERATURE=0.7